# Unified RAG System Environment Configuration
# Copy this file to .env and fill in your actual values

# Domain Configuration
DOMAIN_NAME=yourdomain.com

# SiYuan Configuration
SIYUAN_AUTH_CODE=your_siyuan_auth_code_here

# Qdrant Configuration (usually no need to change if using Docker)
QDRANT_URL=http://qdrant:6333

# SQLite Database Path (inside container)
SQLITE_PATH=/app/data/knowledge.db

# LLM Provider API Keys (optional - system works without them via graceful degradation)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free # Optional: specify model for OpenRouter

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance Tuning
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CACHE_TTL_SECONDS=3600

# Security
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=api.yourdomain.com

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/opt/rag-backups

# Development/Production Mode
ENVIRONMENT=production
